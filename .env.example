# Copy this file to `.env` (which is gitignored) and fill in REAL values there.
# This template is committed — never put real secrets in it.
# The app loads `.env` at startup via spring-dotenv; OS env vars override it.

# --- Server ---
SERVER_PORT=8080
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# --- Database ---
DB_URL=jdbc:postgresql://localhost:5432/mailstock
DB_USER=postgres
DB_PASSWORD=your-db-password

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- SMTP ---
# Port 465 = implicit SSL (SMTP_SSL=true, SMTP_STARTTLS=false)  <- InstAddr / kuku.lu
# Port 587 = STARTTLS      (SMTP_SSL=false, SMTP_STARTTLS=true)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SSL=true
SMTP_STARTTLS=false
SMTP_USER=your@example.com
SMTP_PASSWORD=your-smtp-password
MAIL_FROM=no-reply@mailstock.store
MAIL_FROM_NAME=MailStock.store

# --- JWT (REQUIRED — app will not boot without it; min 256-bit / 32+ chars) ---
JWT_SECRET=replace-me-with-a-long-random-string-of-at-least-32-chars
JWT_ACCESS_TTL=30
JWT_REFRESH_TTL=14

# --- Binance deposit instructions (shown to buyers) ---
BINANCE_DEPOSIT_WALLET=TXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BINANCE_NETWORK=TRC20-USDT

# --- Binance auto-credit poller (optional) ---
# Personal Binance Spot API key with "Enable Reading" ONLY (no trading, no withdrawals),
# IP-whitelisted to this server. When enabled, a scheduled job reads your deposit history
# and auto-credits buyer deposits whose txid matches a confirmed on-chain transfer.
# Keep BINANCE_POLL_ENABLED=false to stay on the manual admin-approval flow.
BINANCE_POLL_ENABLED=false
BINANCE_API_KEY=your-read-only-binance-api-key
BINANCE_API_SECRET=your-read-only-binance-api-secret
BINANCE_API_BASE=https://api.binance.com
BINANCE_COIN=USDT
BINANCE_LOOKBACK_MINUTES=1440
BINANCE_POLL_INTERVAL_MS=120000
BINANCE_AMOUNT_TOLERANCE=0.01

# --- Telegram bot (optional) ---
# Create a bot with @BotFather, then set the token + @username here.
# Keep TELEGRAM_ENABLED=false to run without the bot.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your-botfather-token
TELEGRAM_BOT_USERNAME=your_bot_username
# The bot calls this same backend, so its API base auto-follows SERVER_PORT.
# Leave unset. Only set TELEGRAM_API_BASE to override with a different host.
