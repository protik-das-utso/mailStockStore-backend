# Copy this file to `.env` (which is gitignored) and fill in REAL values there.
# This template is committed — never put real secrets in it.
# The app loads `.env` at startup via spring-dotenv; OS env vars override it.

# --- Server ---
# On Render, PORT is auto-provided. Set SERVER_PORT for local dev.
SERVER_PORT=8080
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# --- Database ---
# Railway provides both internal and external URLs:
# - Internal (from Railway container): postgres-hj9p.railway.internal:5432 (no SSL)
# - External (from your machine): roundhouse.proxy.rlwy.net:31532 (with SSL)
# For production running in Railway: use internal URL
# For local dev: set up local PostgreSQL or use external URL with SSL=require
DB_HOST=postgres-hj9p.railway.internal
DB_PORT=5432
DB_NAME=railway
DB_USER=postgres
DB_PASSWORD=your-db-password-from-railway-dashboard
DB_SSL_MODE=disable

# --- Redis ---
# On Render, use the Redis add-on (check dashboard for credentials).
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Email (Resend HTTP API — not SMTP; many PaaS hosts, e.g. Railway Hobby, block outbound SMTP) ---
# Sign up at resend.com, verify a sending domain, and paste the API key here.
RESEND_API_KEY=your-resend-api-key
MAIL_FROM=no-reply@mailstock.store
MAIL_FROM_NAME=MailStock.store

# --- JWT (REQUIRED — app will not boot without it; min 256-bit / 32+ chars) ---
JWT_SECRET=replace-me-with-a-long-random-string-of-at-least-32-chars
JWT_ACCESS_TTL=30
JWT_REFRESH_TTL=14

# --- Recovery mailbox encryption (REQUIRED — app will not boot without it) ---
# Encrypts the POP3 passwords of recovery mailboxes at rest (AES-GCM). Any long random string;
# changing it later makes already-saved mailbox passwords unreadable (re-enter them in the admin panel).
RECOVERY_ENC_KEY=replace-me-with-another-long-random-string

# --- Binance deposit instructions (shown to buyers) ---
BINANCE_DEPOSIT_WALLET=TXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BINANCE_NETWORK=TRC20-USDT

# --- Binance auto-credit poller (optional) ---
# Personal Binance Spot API key with "Enable Reading" ONLY (no trading, no withdrawals),
# IP-whitelisted to this server. When enabled, a scheduled job reads your deposit history
# and auto-credits buyer deposits whose txid matches a confirmed on-chain transfer.
# Keep BINANCE_POLL_ENABLED=false to stay on the manual admin-approval flow.
BINANCE_POLL_ENABLED=false
BINANCE_API_KEY=your-read-only-binance-api-key
BINANCE_API_SECRET=your-read-only-binance-api-secret
BINANCE_API_BASE=https://api.binance.com
BINANCE_COIN=USDT
BINANCE_LOOKBACK_MINUTES=1440
BINANCE_POLL_INTERVAL_MS=120000
BINANCE_AMOUNT_TOLERANCE=0.01

# --- Telegram bot (optional) ---
# Create a bot with @BotFather, then set the token + @username here.
# IMPORTANT: Keep TELEGRAM_ENABLED=false locally (polling conflict if multiple instances use same token).
# Only set to TRUE on production/Railway when this is the sole instance polling that token.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your-botfather-token
TELEGRAM_BOT_USERNAME=your_bot_username
# The bot calls this same backend, so its API base auto-follows SERVER_PORT.
# Leave unset. Only set TELEGRAM_API_BASE to override with a different host.
